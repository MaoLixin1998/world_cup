#!/usr/bin/env sh
set -eu

# 本项目优先使用用户统一工具目录，避免不同机器上的系统 Gradle/JDK 版本漂移。
TOOLS_DIR="${TOOLS_DIR:-/Users/mao/tools}"
export JAVA_HOME="${JAVA_HOME:-${TOOLS_DIR}/jdk-21/Contents/Home}"
export GRADLE_USER_HOME="${GRADLE_USER_HOME:-${TOOLS_DIR}/gradle-repo}"
GRADLE_BIN="${GRADLE_BIN:-${TOOLS_DIR}/gradle-8.14.3/bin/gradle}"

exec "${GRADLE_BIN}" "$@"
